# ─── Clerk Auth ───────────────────────────────────────────────────────────────
# Required. Automatically set by Replit on the Replit deployment.
# On Cloudflare Pages (or any static host): copy the value from your Replit
# project's Secrets tab → VITE_CLERK_PUBLISHABLE_KEY.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Required on Cloudflare Pages / any static host that is NOT on replit.app.
# Set this to:  https://<your-replit-app-name>.replit.app/api/__clerk
# This routes Clerk authentication through the Replit backend proxy so that
# the test-mode Clerk key works on any domain.
VITE_CLERK_PROXY_URL=

# ─── API Backend ──────────────────────────────────────────────────────────────
# Optional. When set, all /api/* calls are prefixed with this URL so that a
# Cloudflare Pages static frontend can talk to the separately-deployed backend.
# Set this to:  https://<your-replit-app-name>.replit.app/api
# Leave blank when the frontend and backend are served from the same origin
# (Replit dev + Replit production deployments).
VITE_API_BASE_URL=
